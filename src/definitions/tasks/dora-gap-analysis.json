  "stage_state_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "scoping": {
        "type": "object",
        "properties": {
          "entity_name": {
            "type": "string",
            "minLength": 1
          },
          "entity_type": {
            "type": "string",
            "enum": [
              "credit_institution",
              "payment_institution",
              "e_money_institution",
              "investment_firm",
              "crypto_asset_service_provider",
              "central_securities_depository",
              "central_counterparty",
              "trading_venue",
              "trade_repository",
              "uctis_management_company",
              "aifm",
              "data_reporting_service_provider",
              "insurance_undertaking",
              "reinsurance_undertaking",
              "insurance_intermediary",
              "iorp",
              "credit_rating_agency",
              "statutory_auditor",
              "crowdfunding_service_provider",
              "securitisation_repository",
              "ict_third_party_service_provider"
            ]
          },
          "is_microenterprise": {
            "type": "boolean"
          },
          "designated_for_tlpt": {
            "type": "boolean"
          },
          "member_state": {
            "type": "string"
          },
          "competent_authority": {
            "type": "string"
          }
        },
        "required": [
          "entity_name",
          "entity_type",
          "is_microenterprise",
          "designated_for_tlpt"
        ]
      },
      "sections": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "section_id": {
              "type": "string"
            },
            "section_name": {
              "type": "string"
            },
            "provisions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "provision_ref": {
                    "type": "string"
                  },
                  "regulation_source": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "compliant",
                      "partially_compliant",
                      "non_compliant",
                      "not_applicable",
                      "not_assessed"
                    ]
                  },
                  "evidence": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": [
                            "policy",
                            "procedure",
                            "test_report",
                            "config",
                            "contract",
                            "training_record",
                            "other"
                          ]
                        },
                        "reference": {
                          "type": "string"
                        },
                        "date": {
                          "type": "string"
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type",
                        "reference"
                      ]
                    }
                  },
                  "gaps": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "exemption_basis": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "assessed_by": {
                    "type": "string"
                  },
                  "assessed_at": {
                    "type": "string"
                  }
                },
                "required": [
                  "provision_ref",
                  "regulation_source",
                  "status",
                  "evidence",
                  "gaps",
                  "exemption_basis",
                  "assessed_by",
                  "assessed_at"
                ]
              }
            }
          },
          "required": [
            "section_id",
            "section_name",
            "provisions"
          ]
        }
      }
    },
    "required": [
      "scoping",
      "sections"
    ]
  },
  "completion_criteria": {
    "required_fields": [
      {
        "field": "sections",
        "rule": "min_count",
        "value": 1,
        "message": "At least one section is required"
      }
    ],
    "rules": [
      {
        "id": "all_provisions_assessed",
        "description": "Every provision in every applicable section must be assessed",
        "severity": "required",
        "message_template": "Provision '{provision_ref}' has not been assessed"
      },
      {
        "id": "gaps_required_for_non_compliant",
        "description": "Non-compliant and partially-compliant provisions must have gap descriptions",
        "severity": "required",
        "message_template": "Provision '{provision_ref}' is {status} but has no gap description"
      },
      {
        "id": "exemption_basis_required",
        "description": "Not-applicable provisions must have an exemption basis citing specific articles",
        "severity": "required",
        "message_template": "Provision '{provision_ref}' is marked not_applicable but has no exemption basis"
      },
      {
        "id": "evidence_required_for_compliant",
        "description": "Compliant and partially-compliant provisions must have at least one evidence record",
        "severity": "required",
        "message_template": "Provision '{provision_ref}' is {status} but has no evidence"
      },
      {
        "id": "assessor_metadata_present",
        "description": "Every assessed provision must have assessor name and timestamp",
        "severity": "required",
        "message_template": "Provision '{provision_ref}' is missing assessor metadata"
      },
      {
        "id": "evidence_has_date",
        "description": "Evidence records should include review/approval dates",
        "severity": "warning",
        "message_template": "Evidence '{reference}' has no date"
      },
      {
        "id": "gap_description_quality",
        "description": "Gap descriptions should be detailed enough for audit (minimum 10 words)",
        "severity": "warning",
        "message_template": "Gap description for '{provision_ref}' is too brief"
      },
      {
        "id": "exemption_basis_quality",
        "description": "Exemption basis should cite specific legal basis (minimum 5 words)",
        "severity": "warning",
        "message_template": "Exemption basis for '{provision_ref}' is too brief"
      }
    ],
    "soft_warnings": []
  },
  "quality_rubric": {}
}
