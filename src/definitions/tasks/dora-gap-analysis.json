        {"ref": "DORA Art. 5(3)", "source": "dora", "topic": "Internal audit of ICT risk management"},
        {"ref": "DORA Art. 5(4)", "source": "dora", "topic": "Follow-up and remediation of ICT audit findings"},
        {"ref": "DORA Art. 6(1)", "source": "dora", "topic": "ICT systems, protocols and tools requirements"},
        {"ref": "DORA Art. 6(2)", "source": "dora", "topic": "ICT systems resilience and availability"},
