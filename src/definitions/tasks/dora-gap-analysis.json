{
  "id": "dora_gap_analysis",
  "name": "DORA Gap Analysis",
  "category": "compliance_gap_analysis",
  "version": "1.0",
  "standalone": true,
  "used_in_workflows": [
    "dora_compliance_programme"
  ],
  "description": "Structured gap analysis against the Digital Operational Resilience Act (DORA, Regulation (EU) 2022/2554) and all 10 implementing technical standards (8 RTS + 2 ITS). Provision-level assessment across 5 pillars with entity scoping, proportionality, and structured evidence records.",
  "estimated_duration": "2-4 hours",
  "dependencies": [],
  "mcp_tools": [
    {
      "mcp": "eu-regulations-mcp",
      "tools": [
        "get_article",
        "search_regulations"
      ],
      "when": "always",
      "guidance": "Fetch article text before each assessment. Use get_article with regulation ID (e.g. 'DORA', 'DORA_RTS_ICT_RISK') and article number."
    },
    {
      "mcp": "security-controls-mcp",
      "tools": [
        "search_controls",
        "get_control"
      ],
      "when": "evidence_gathering",
      "guidance": "When user describes controls in place, map to framework controls (ISO 27001, NIST CSF) for structured evidence."
    }
  ],
  "prompting_guidance": "Start with entity scoping: ask entity name, type (from the 21 DORA categories in Article 2), whether they are a microenterprise, and whether designated for TLPT by their competent authority. Explain what each choice means for the assessment scope. Then work pillar by pillar. For each pillar, explain what it covers, then present provisions in groups of 3-5. For each provision, fetch the article text from eu-regulations-mcp using get_provision, then ask the user to assess their compliance status and provide evidence. For compliant items, require at least one structured evidence record (policy, procedure, test report, etc.). For non-compliant items, require a gap description. For not-applicable items, require an exemption basis citing a specific article. After each pillar, run check_stage_completeness to show progress. After all pillars, run generate_gap_summary to produce the final assessment.",
  "sections_definition": [
